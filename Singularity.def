Bootstrap: docker
From: ubuntu:22.04

%labels
    Maintainer   HPC-Workflow-Team
    Version      0.1.0
    Description  WIEN2k Parallel Config & Job Dispatcher (Production HPC Container)
    WIEN2k_Compat 19.1+ 21.1+ 23.1+
    MPI_Flavors   OpenMPI-4.1 MPICH-4.1 IntelMPI-2021
    Math_Libraries FFTW-3.3 LAPACK-3.11 ScaLAPACK-2.2 ELPA-2023.11

%environment
    # ── Core paths ──────────────────────────────────────────────
    export WIEN2K_GEN_ROOT="/opt/forge"
    export PATH="${WIEN2K_GEN_ROOT}/bin:${WIEN2K_GEN_ROOT}/scripts:${PATH}"
    export PYTHONPATH="${WIEN2K_GEN_ROOT}/lib/python3.11/site-packages:${PYTHONPATH}"

    # ── OpenMP / MKL threading defaults (override per-job) ──────
    export OMP_NUM_THREADS="${OMP_NUM_THREADS:-1}"
    export OMP_STACKSIZE="${OMP_STACKSIZE:-512M}"
    export MKL_NUM_THREADS="${MKL_NUM_THREADS:-1}"
    export KMP_AFFINITY="granularity=fine,compact,1,0"
    export OPENBLAS_NUM_THREADS="${OPENBLAS_NUM_THREADS:-1}"

    # ── MPI defaults (environment modules swap these) ──────────
    export MPI_HOME="/opt/openmpi"
    export MPI_BIN="${MPI_HOME}/bin"
    export MPI_LIB="${MPI_HOME}/lib"
    export PATH="${MPI_BIN}:${PATH}"
    export LD_LIBRARY_PATH="${MPI_LIB}:${LD_LIBRARY_PATH}"

    # ── ScaLAPACK / ELPA hints ──────────────────────────────────
    export ELPA_HOME="/opt/elpa"
    export SCALAPACK_HOME="/opt/scalapack"

    # ── Lustre striping hints (respected by forge) ─────────
    export SCRATCH_STRIPING_FACTOR="${SCRATCH_STRIPING_FACTOR:-8}"
    export SCRATCH_STRIPING_UNIT="${SCRATCH_STRIPING_UNIT:-4194304}"

    # ── Python / runtime behaviour ──────────────────────────────
    export PYTHONUNBUFFERED=1
    export LC_ALL="C.UTF-8"

%files
    pyproject.toml                          /src/pyproject.toml
    README.md                               /src/README.md
    src/                                    /src/src/
    offline_packages/requirements-offline.txt /opt/forge/requirements-offline.txt

%post -c /bin/bash
    set -euo pipefail

    # ──────────────────────────────────────────────────────────────
    # 1. Base system & build toolchain
    # ──────────────────────────────────────────────────────────────
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq
    apt-get install -y --no-install-recommends \
        build-essential          \
        g++ gfortran             \
        cmake autoconf automake libtool pkg-config \
        wget curl ca-certificates \
        python3 python3-dev python3-pip python3-venv \
        libopenmpi-dev openmpi-bin \
        libmpich-dev mpich        \
        libfftw3-dev libfftw3-mpi-dev \
        liblapack-dev libblas-dev libscalapack-openmpi-dev libscalapack-mpich-dev \
        libhwloc-dev libnuma-dev \
        libhdf5-openmpi-dev libhdf5-mpich-dev \
        hwloc numactl rsync openssh-client \
        vim less git procps \
        libxml2-dev libxslt1-dev \
        rocm-smi-lib 2>/dev/null || true

    # ──────────────────────────────────────────────────────────────
    # 2. Python environment
    # ──────────────────────────────────────────────────────────────
    python3 -m pip install --no-cache-dir --upgrade pip setuptools wheel
    # Install from offline requirements if available, otherwise from pyproject
    if [ -f /opt/forge/requirements-offline.txt ]; then
        python3 -m pip install --no-cache-dir -r /opt/forge/requirements-offline.txt
    fi
    python3 -m pip install --no-cache-dir -e /src/

    # ──────────────────────────────────────────────────────────────
    # 3. Directory layout
    # ──────────────────────────────────────────────────────────────
    mkdir -p /opt/forge/{bin,scripts,lib/modules,etc,examples,scratch,cache}
    mkdir -p /opt/{openmpi,mpich,fftw,lapack,scalapack,elpa}/lib
    mkdir -p /opt/intel/oneapi/mpi/latest  # stub for Intel MPI module

    # Symlink CLI entry points
    for tool in forge forge_sbatch forge_wizard forge_api; do
        if which "${tool}" &>/dev/null; then
            ln -sf "$(which "${tool}")" "/opt/forge/bin/${tool}"
        fi
    done

    # ──────────────────────────────────────────────────────────────
    # 4. Build ELPA (Eigenvalue SoLvers for Petaflop-Applications)
    #    from source for ELPA Stage-1 / Stage-2 support
    # ──────────────────────────────────────────────────────────────
    ELPA_VER="2023.11.001"
    cd /tmp
    wget -q "https://gitlab.mpcdf.mpg.de/elpa/elpa/-/archive/elpa-${ELPA_VER}/elpa-elpa-${ELPA_VER}.tar.gz" \
        -O elpa.tar.gz 2>/dev/null || echo "ELPA download skipped (offline build)"
    if [ -f elpa.tar.gz ]; then
        tar xzf elpa.tar.gz
        cd elpa-elpa-${ELPA_VER} 2>/dev/null || cd elpa-* 2>/dev/null || true
        mkdir build && cd build
        ../configure \
            --prefix=/opt/elpa \
            --enable-openmp \
            FCFLAGS="-O3 -march=native" \
            CFLAGS="-O3 -march=native" \
            2>/dev/null || echo "ELPA configure skipped (no network)"
        make -j$(nproc) 2>/dev/null && make install 2>/dev/null || echo "ELPA build skipped"
    fi

    # ──────────────────────────────────────────────────────────────
    # 5. Build FFTW with OpenMPI + threads support
    # ──────────────────────────────────────────────────────────────
    FFTW_VER="3.3.10"
    cd /tmp
    wget -q "https://www.fftw.org/fftw-${FFTW_VER}.tar.gz" -O fftw.tar.gz 2>/dev/null || true
    if [ -f fftw.tar.gz ]; then
        tar xzf fftw.tar.gz && cd fftw-${FFTW_VER}
        ./configure --prefix=/opt/fftw --enable-openmp --enable-mpi --enable-shared \
            MPICC=mpicc 2>/dev/null || true
        make -j$(nproc) 2>/dev/null && make install 2>/dev/null || echo "FFTW build skipped"
    fi

    # ──────────────────────────────────────────────────────────────
    # 6. Install Lmod-style environment modules for MPI switching
    # ──────────────────────────────────────────────────────────────
    cat > /opt/forge/etc/modules.sh << 'LMODEOF'
#!/bin/bash
# Lmod-compatible environment modules for forge HPC container
# Usage: source /opt/forge/etc/modules.sh ; module load mpi/openmpi

MODULEPATH="/opt/forge/lib/modules"

module() {
    case "$1" in
        load)   source "${MODULEPATH}/${2//\//-}" ;;
        unload) module_unload "${2//\//-}" ;;
        list)   echo "Loaded: ${_MODULE_LOADED:-none}" ;;
        avail)  ls "${MODULEPATH}/" 2>/dev/null || echo "No modules" ;;
        *)      echo "module: unknown command $1" ;;
    esac
}
LMODEOF

    # OpenMPI module
    cat > /opt/forge/lib/modules/mpi-openmpi << 'MPIMOD'
export MPI_HOME="/opt/openmpi"
export MPI_BIN="${MPI_HOME}/bin"
export MPI_LIB="${MPI_HOME}/lib"
export PATH="${MPI_BIN}:${PATH}"
export LD_LIBRARY_PATH="${MPI_LIB}:${LD_LIBRARY_PATH}"
export OMPI_MCA_btl="^openib"          # Force TCP on container nets (override for IB)
export OMPI_MCA_btl_openib_if_include="mlx5_0,mlx5_1"
export OMPI_MCA_rmaps_base_oversubscribe=1
export _MODULE_MPI="openmpi"
echo "Loaded OpenMPI 4.1"
MPIMOD

    # MPICH module
    cat > /opt/forge/lib/modules/mpi-mpich << 'MPIMOD'
export MPI_HOME="/opt/mpich"
export MPI_BIN="${MPI_HOME}/bin"
export MPI_LIB="${MPI_HOME}/lib"
export PATH="${MPI_BIN}:${PATH}"
export LD_LIBRARY_PATH="${MPI_LIB}:${LD_LIBRARY_PATH}"
export HYDRA_HOST_FILE="/tmp/mpich_hosts"
export _MODULE_MPI="mpich"
echo "Loaded MPICH 4.1"
MPIMOD

    # Intel MPI module (stub for sites with Intel license)
    cat > /opt/forge/lib/modules/mpi-intel << 'MPIMOD'
if [ -d /opt/intel/oneapi/mpi/latest ]; then
    export MPI_HOME="/opt/intel/oneapi/mpi/latest"
    export MPI_BIN="${MPI_HOME}/bin"
    export MPI_LIB="${MPI_HOME}/lib"
    export PATH="${MPI_BIN}:${PATH}"
    export LD_LIBRARY_PATH="${MPI_LIB}:${LD_LIBRARY_PATH}"
    export I_MPI_FABRICS="shm:ofi"
    export I_MPI_FALLBACK=0
    export _MODULE_MPI="intel"
    echo "Loaded Intel MPI"
else
    echo "Intel MPI not installed – using fallback OpenMPI"
    export _MODULE_MPI="openmpi"
fi
MPIMOD

    # ELPA module
    cat > /opt/forge/lib/modules/elpa << 'ELPAMOD'
if [ -d /opt/elpa ]; then
    export ELPA_HOME="/opt/elpa"
    export LD_LIBRARY_PATH="${ELPA_HOME}/lib:${LD_LIBRARY_PATH}"
    export ELPA_KERNEL="avx2"
    echo "Loaded ELPA 2023.11 (kernels: generic avx avx2 avx512)"
else
    echo "ELPA not built (source unavailable)"
fi
ELPAMOD

    # CUDA module
    cat > /opt/forge/lib/modules/cuda << 'CUDAMOD'
if [ -d /usr/local/cuda ] || [ -d /opt/cuda ]; then
    export CUDA_HOME="${CUDA_HOME:-/usr/local/cuda}"
    export PATH="${CUDA_HOME}/bin:${PATH}"
    export LD_LIBRARY_PATH="${CUDA_HOME}/lib64:${LD_LIBRARY_PATH}"
    echo "Loaded CUDA (${CUDA_HOME})"
else
    echo "CUDA not available in this container"
fi
CUDAMOD

    # Default: load OpenMPI
    source /opt/forge/etc/modules.sh
    module load mpi/openmpi

    # ──────────────────────────────────────────────────────────────
    # 7. Install forge launcher scripts
    # ──────────────────────────────────────────────────────────────
    cat > /opt/forge/scripts/forge_wrapper << 'WRAPEOF'
#!/bin/bash
# WIEN2k parallel launcher wrapper for Singularity/HPC
set -euo pipefail

source /opt/forge/etc/modules.sh 2>/dev/null || true

# Default MPI detection
if [ -z "${_MODULE_MPI:-}" ]; then
    module load mpi/openmpi 2>/dev/null || true
fi

# ELPA GPU awareness
if [ -n "${CUDA_VISIBLE_DEVICES:-}" ] && [ "${ELPA_USE_GPU:-0}" = "1" ]; then
    module load elpa 2>/dev/null || true
    module load cuda 2>/dev/null || true
fi

exec python3 -m forge.cli "$@"
WRAPEOF
    chmod +x /opt/forge/scripts/forge_wrapper

    # Bashrc auto-source for interactive use
    cat >> /etc/bash.bashrc << 'BASH'
if [ -f /opt/forge/etc/modules.sh ]; then
    source /opt/forge/etc/modules.sh 2>/dev/null
fi
BASH

    # ──────────────────────────────────────────────────────────────
    # 8. Cleanup
    # ──────────────────────────────────────────────────────────────
    rm -rf /tmp/* /var/lib/apt/lists/* /root/.cache
    apt-get clean

%runscript
    #!/bin/bash
    exec /opt/forge/scripts/forge_wrapper "$@"

%startscript
    #!/bin/bash
    # Instance startup: print environment summary
    echo "========================================"
    echo " WIEN2k Gen HPC Container v0.1.0"
    echo "========================================"
    echo "MPI:  $(which mpirun 2>/dev/null || echo 'default')"
    echo "Python: $(python3 --version)"
    echo "ELPA:  ${ELPA_HOME:-not built}"
    echo ""
    echo "Modules: source /opt/forge/etc/modules.sh"
    echo "Available: $(ls /opt/forge/lib/modules/ 2>/dev/null | tr '\n' ' ')"
    echo "========================================"

%test
    # ── Build-time validation ────────────────────────────────────
    python3 -c "import forge; print(f'forge {forge.__version__} OK')" || exit 1
    python3 -c "from forge.config import AppConfig; print('Config OK')" || exit 1
    python3 -c "from forge.core.topology import Topology; print('Topology OK')" || exit 1
    python3 -c "from forge.core.scheduler import detect; print('Scheduler OK')" || exit 1
    echo "All import checks passed."

%help
    WIEN2k Gen HPC Container — Production Environment
    =================================================
    Usage:
      singularity run forge.sif [args]         # Run forge CLI
      singularity exec forge.sif bash           # Interactive shell
      singularity exec forge.sif forge_sbatch  # Submit via SLURM

    Environment modules (source /opt/forge/etc/modules.sh):
      module load mpi/openmpi    # OpenMPI 4.1 (default)
      module load mpi/mpich      # MPICH 4.1
      module load mpi/intel      # Intel MPI (if installed)
      module load elpa           # ELPA eigenvalue solver
      module load cuda           # CUDA toolkit

    MPI benchmarks:
      mpirun --allow-run-as-root -np 4 /opt/forge/scripts/forge_wrapper benchmark

    Lustre scratch hints:
      export SCRATCH_STRIPING_FACTOR=8
      lfs setstripe -c $SCRATCH_STRIPING_FACTOR /scratch/user/wien2k
